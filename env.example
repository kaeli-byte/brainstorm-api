# Runtime contract:
# - In production, DATABASE_URL must be set or server boot fails.
# - Before starting against Postgres, run: pnpm db:migrate
# - /health reports process liveness and persistence mode.
# - /ready reports dependency readiness and fails when persistence is unavailable.
# - USE_FAKE_LLM=true is test-only and is rejected outside test runtime.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/brainstorm
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
SESSION_API_PORT=3000
LOG_LEVEL=info
USE_FAKE_LLM=false
